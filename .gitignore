# Tajne i lokalna konfiguracija — NIKAD u git
# (sve u config/ OSIM predloška i .htaccess — pokriva config.php, *.bak.php, kopije)
config/*
!config/config.sample.php
!config/.htaccess
*.bak
*.bak.php
install/.lock

# Korisnički sadržaj
uploads/*
!uploads/.htaccess

# Logovi
logs/*
!logs/.htaccess
*.log

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Interni dokumenti — ne idu na javni repo (ostaju lokalno)
docs/

# JavaScript izvor — ne ide na javni repo (objavljujes obfusciranu verziju)
assets/js/*.js
