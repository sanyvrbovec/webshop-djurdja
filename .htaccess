# ============================================================
# ĐurđaShop — Apache konfiguracija
# ============================================================

Options -Indexes
ServerSignature Off

# Blokiraj skrivene datoteke (.git, .env, .lock…)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "\.(sql|log|md|lock|sample\.php)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Lijepi URL-ovi (rade i u poddirektoriju — relativna pravila)
    RewriteRule ^p/([a-z0-9-]+)/?$ proizvod.php?slug=$1 [L,QSA]
    RewriteRule ^k/([a-z0-9-]+)/?$ proizvodi.php?cat=$1 [L,QSA]
    RewriteRule ^s/([a-z0-9-]+)/?$ stranica.php?slug=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]
    RewriteRule ^robots\.txt$ robots.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Keširanje statike
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
</IfModule>

AddDefaultCharset utf-8
